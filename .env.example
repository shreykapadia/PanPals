# Copy this file to .env and fill in real values. NEVER commit .env.
# Get these from Supabase → Project Settings → API (see SHREY-SETUP-RUNBOOK.md Part 2).

# Client-safe values (the EXPO_PUBLIC_ prefix ships them to the app)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server / local-tooling only — do NOT prefix with EXPO_PUBLIC_ (keeps it out of the app bundle)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
